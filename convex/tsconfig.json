{
  /* This TypeScript project config describes the environment that
   * Convex functions run in and is used to typecheck them.
   * You can modify it, but some settings required to use Convex.
   */
  "compilerOptions": {
    /* These settings are not required by Convex and can be modified. */
    "allowJs": true,
    "strict": true,
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    /* TS 6 defaults `types` to [] (was: all @types). Convex functions use
     * Node globals (e.g. process.env in auth.config.ts), so request them. */
    "types": ["node"],
    /* better-auth's own .d.ts files reference optional peer types we don't
     * install (bun:sqlite, @cloudflare/workers-types) and have an unrelated
     * internal generic-indexing error in its organization plugin types
     * (a plugin we don't use). Matches root tsconfig.json, which already
     * sets this. */
    "skipLibCheck": true,

    /* These compiler options are required by Convex */
    "target": "ESNext",
    "lib": ["ES2021", "dom"],
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["./**/*"],
  "exclude": ["./_generated", "**/*.test.ts"]
}
